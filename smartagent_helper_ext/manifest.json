{
  "manifest_version": 3,
  "name": "SmartAgent + Always Active",
  "version": "1.0.2",
  "description": "SmartAgent Helper combined seamlessly with Always Active Window.",
  "default_locale": "en",
  "update_url": "https://clients2.google.com/service/update2/crx",
  "homepage_url": "https://agentbridge-cloud.vercel.app/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "data/icons/256.png",
    "512": "data/icons/512.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "master_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js",
        "content-panel.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "SmartAgent Helper"
  },
  "options_ui": {
    "open_in_tab": true,
    "page": "data/options/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "panel.css",
        "tailwind.css",
        "jquery-bypass.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {}
  }
}