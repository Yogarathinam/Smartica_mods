// Step 1: Get question paragraphs
const paragraphs = Array.from(document.querySelectorAll('p')).filter(p =>
  p.offsetParent !== null && p.innerText.trim().length > 0
);

// Step 2: Get all divs with text like "Input 1 :", "Output 1 :", etc.
const sampleDivs = Array.from(document.querySelectorAll('div')).filter(div =>
  div.offsetParent !== null &&
  div.innerText.trim().match(/^(Input|Output) \d+ ?:$/)
);

// Step 3: Get all <pre> blocks
const preBlocks = Array.from(document.querySelectorAll('pre')).filter(pre =>
  pre.offsetParent !== null && pre.innerText.trim().length > 0
);

// Step 4: Map labeled blocks to content
let sampleIO = '';
let preIndex = 0;

sampleDivs.forEach(div => {
  const label = div.innerText.trim().replace(':', '');
  const content = preBlocks[preIndex]?.innerText.trim();
  if (content) {
    sampleIO += `\n📥 ${label}:\n${content}\n`;
    preIndex++;
  }
});

// Step 5: Combine everything
let fullQuestion = '🧠 Problem:\n';
paragraphs.forEach(p => {
  fullQuestion += p.innerText.trim() + '\n';
});
fullQuestion += sampleIO;

console.log(fullQuestion);
